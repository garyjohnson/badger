#!/usr/bin/env node
'use strict'

const path = require('path')
const command = process.argv[2]

const commands = {
  install: '../lib/install',
  uninstall: '../lib/uninstall',
  submit: '../lib/submit',
  hook: '../lib/hook',
  version: () => {
    const pkg = require('../package.json')
    console.log(`badger ${pkg.version}`)
  },
  help: usage,
  '--help': usage,
  '-h': usage,
  '--version': () => commands.version(),
  '-v': () => commands.version()
}

function usage () {
  console.log(`badger — A lightweight quality gate for Claude Code sessions.

Usage:
  badger install              Interactive project setup
  badger uninstall            Remove badger from the current project
  badger submit               Run pre-submit checks and prompt review
  badger submit --finalize    Re-run checks and execute submit action
  badger hook <event>         Run a hook (called by Claude Code)
  badger version              Print version

See https://github.com/garyjohnson/badger for more information.`)
}

async function main () {
  if (!command) {
    usage()
    process.exit(0)
  }

  const entry = commands[command]
  if (!entry) {
    console.error(`badger: unknown command: ${command}`)
    usage()
    process.exit(1)
  }

  if (typeof entry === 'function') {
    await entry()
  } else {
    const mod = require(entry)
    await mod(process.argv.slice(3))
  }
}

main().catch(err => {
  console.error(`badger: ${err.message}`)
  process.exit(1)
})
